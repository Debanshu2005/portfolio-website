# GitHub Personal Access Token
# Recommended for reliable GitHub API refreshes and required for contribution data.
# Create one at: https://github.com/settings/tokens
# Fine-grained token: read-only access to public repositories is enough.
# Classic token scopes: public_repo and read:user are enough for this site.
GITHUB_TOKEN=ghp_xxxx

# Your GitHub username
GITHUB_USERNAME=Debanshu2005

# Your deployed site URL
NEXT_PUBLIC_SITE_URL=https://debanshu.dev

# Formspree endpoint for contact form
# Create one at: https://formspree.io
FORMSPREE_ENDPOINT=https://formspree.io/f/xxxx
